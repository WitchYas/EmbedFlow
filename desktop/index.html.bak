<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control Plane | AI Embedded DevOps</title>
    <!-- Tailwind CDN with Font Support -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d1117; color: #e6edf3; margin: 0; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(22, 27, 34, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(48, 54, 61, 1); }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #30363d; border-radius: 10px; }
        
        @keyframes pulse-subtle { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .animate-pulse-subtle { animation: pulse-subtle 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        
        .status-dot { width: 8px; height: 8px; border-radius: 50%; }
        .status-up { background: #238636; box-shadow: 0 0 8px #238636; }
        .status-down { background: #da3633; }
    </style>
</head>
<body class="overflow-hidden h-screen flex">
    <div id="app" class="flex w-full h-full"></div>

    <script type="importmap">
    {
        "imports": {
            "react": "https://esm.sh/react@18.2.0",
            "react-dom": "https://esm.sh/react-dom@18.2.0",
            "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
            "lucide-react": "https://esm.sh/lucide-react@0.344.0?deps=react@18.2.0",
            "framer-motion": "https://esm.sh/framer-motion@10.16.4?deps=react@18.2.0"
        }
    }
    </script>

    <script type="module">
        import React from 'react';
        import { createRoot } from 'react-dom/client';
        import * as Lucide from 'lucide-react';

        const { useState, useEffect, useCallback, useRef } = React;
        
        // Destructure icons with robust fallback
        const getIcon = (name) => {
            const Icon = Lucide[name];
            if (Icon) return (props) => React.createElement(Icon, props);
            const emojis = {
                LayoutDashboard: '📊', Activity: '📈', Play: '▶️', MessageSquare: '💬', 
                Plus: '➕', Send: '📤', Shield: '🛡️', Cpu: '💻', CheckCircle2: '✅', 
                XCircle: '❌', Sparkles: '✨', Zap: '⚡', Terminal: '⌨️', X: '✖️',
                AlertTriangle: '⚠️', ChevronRight: '➡️'
            };
            return (props) => React.createElement('span', { className: 'text-lg' }, emojis[name] || '•');
        };

        const Icons = {
            LayoutDashboard: getIcon('LayoutDashboard'),
            Activity: getIcon('Activity'),
            Play: getIcon('Play'),
            MessageSquare: getIcon('MessageSquare'),
            Plus: getIcon('Plus'),
            Send: getIcon('Send'),
            Shield: getIcon('Shield'),
            Cpu: getIcon('Cpu'),
            CheckCircle2: getIcon('CheckCircle2'),
            XCircle: getIcon('XCircle'),
            Sparkles: getIcon('Sparkles'),
            Zap: getIcon('Zap'),
            Terminal: getIcon('Terminal'),
            X: getIcon('X'),
            AlertTriangle: getIcon('AlertTriangle'),
            ChevronRight: getIcon('ChevronRight')
        };

        const API_BASE = 'http://172.18.205.88:8000';

        // --- API Client ---
        const api = {
            getRuns: () => fetch(`${API_BASE}/pipeline/runs`).then(r => r.json()),
            getHealth: () => fetch(`${API_BASE}/health`).then(r => r.json()),
            triggerPipeline: (data) => fetch(`${API_BASE}/pipeline/trigger`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            }).then(r => r.json()),
            chat: (runId, message, modelHint = 'phi3') => fetch(`${API_BASE}/pipeline/chat`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ run_id: runId, message, model_hint: modelHint })
            }).then(r => r.json())
        };

        // --- Components ---
        const DecisionBadge = ({ decision }) => {
            const styles = {
                DEPLOY: 'bg-green-500/10 text-green-500 border-green-500/20',
                BLOCK: 'bg-red-500/10 text-red-500 border-red-500/20',
                REVIEW: 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20'
            };
            return React.createElement('span', {
                className: `px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-wider ${styles[decision] || 'bg-white/5 text-white/40 border-white/10'}`
            }, decision || 'RUNNING');
        };

        const LivePipeline = ({ runId, logs, onClose }) => {
            const logEndRef = useRef(null);
            useEffect(() => logEndRef.current?.scrollIntoView({ behavior: 'smooth' }), [logs]);

            const stages = [
                { id: 'security', label: 'Security Scan', icon: Icons.Shield },
                { id: 'testing', label: 'Unit Testing', icon: Icons.Activity },
                { id: 'firmware', label: 'Build Firmware', icon: Icons.Cpu },
            ];

            return React.createElement('div', {
                className: "fixed inset-0 bg-[#0d1117]/95 backdrop-blur-xl z-[100] flex flex-col p-10 border-t border-[#30363d]"
            }, React.createElement('div', { className: "max-w-6xl mx-auto w-full flex flex-col h-full" },
                React.createElement('div', { className: "flex items-center justify-between mb-8" },
                    React.createElement('div', null,
                        React.createElement('h2', { className: "text-2xl font-bold flex items-center gap-3" },
                            React.createElement(Icons.Zap, { className: "text-yellow-500 fill-yellow-500" }),
                            "Pipeline Active: ",
                            React.createElement('span', { className: "font-mono text-blue-500" }, runId.slice(0, 12))
                        ),
                        React.createElement('p', { className: "text-gray-400 mt-1" }, "Real-time telemetry and decision monitoring...")
                    ),
                    React.createElement('button', { onClick: onClose, className: "p-2 hover:bg-white/5 rounded-full" }, React.createElement(Icons.X, { size: 24 }))
                ),
                React.createElement('div', { className: "grid grid-cols-12 gap-8 flex-1 min-h-0" },
                    React.createElement('div', { className: "col-span-4 space-y-4" },
                        stages.map(stage => {
                            const isDone = logs.some(l => (l.agent_name || l.agent || '').toLowerCase().includes(stage.id));
                            return React.createElement('div', {
                                key: stage.id,
                                className: `p-6 rounded-2xl border transition-all duration-500 ${isDone ? 'bg-green-500/10 border-green-500/30' : 'bg-[#161b22] border-[#30363d]'}`
                            }, React.createElement('div', { className: "flex items-center gap-4" },
                                React.createElement('div', { className: `p-3 rounded-lg ${isDone ? 'bg-green-500 text-black' : 'bg-gray-800 text-gray-400'}` }, React.createElement(stage.icon, { size: 20 })),
                                React.createElement('div', null,
                                    React.createElement('div', { className: "font-bold" }, stage.label),
                                    React.createElement('div', { className: "text-xs text-gray-500" }, isDone ? 'Completed' : 'Queued')
                                )
                            ))
                        })
                    ),
                    React.createElement('div', { className: "col-span-8 bg-black rounded-2xl border border-[#30363d] flex flex-col overflow-hidden shadow-2xl" },
                        React.createElement('div', { className: "bg-[#161b22] px-4 py-2 border-b border-[#30363d] flex items-center gap-2" },
                            React.createElement(Icons.Terminal, { size: 14, className: "text-gray-500" }),
                            React.createElement('span', { className: "text-[10px] font-mono text-gray-500 uppercase tracking-widest" }, "Agent Streams")
                        ),
                        React.createElement('div', { className: "flex-1 overflow-y-auto p-6 font-mono text-sm space-y-2 custom-scrollbar" },
                            logs.length === 0 ? React.createElement('div', { className: "text-gray-600 animate-pulse" }, "Starting Agent Orchestration...") :
                            logs.map((log, i) => React.createElement('div', { key: i, className: "flex gap-4 group" },
                                React.createElement('span', { className: "text-gray-600 shrink-0 select-none" }, new Date(log.timestamp).toLocaleTimeString([], { hour12: false })),
                                React.createElement('span', { className: "text-blue-500 shrink-0" }, `[${(log.agent_name || log.agent || 'SYSTEM').toUpperCase()}]`),
                                React.createElement('span', { className: log.level === 'error' ? 'text-red-400' : 'text-gray-300' }, log.message)
                            )),
                            React.createElement('div', { ref: logEndRef })
                        )
                    )
                )
            ));
        };

        const App = () => {
            const [activeTab, setActiveTab] = useState('overview');
            const [runs, setRuns] = useState([]);
            const [selectedRun, setSelectedRun] = useState(null);
            const [healthStatus, setHealthStatus] = useState({ api: 'up', db: 'up', redis: 'up', sim: 'up', ollama: 'up' });
            const [isDeploying, setIsDeploying] = useState(false);
            const [currentRunId, setCurrentRunId] = useState(null);
            const [logs, setLogs] = useState([]);
            const [chatMessage, setChatMessage] = useState("");
            const [chatHistory, setChatHistory] = useState([]);
            const [isTyping, setIsTyping] = useState(false);
            const [activeModel, setActiveModel] = useState('phi3');

            const refreshData = useCallback(async () => {
                try {
                    const data = await api.getRuns();
                    setRuns(data || []);
                    const running = data?.find(r => r.status === 'running');
                    if (running && !currentRunId) {
                        setCurrentRunId(running.id);
                        setIsDeploying(true);
                    }
                    const health = await api.getHealth();
                    setHealthStatus({
                        api: health.status === 'ok' ? 'up' : 'down',
                        db: health.database === 'connected' ? 'up' : 'down',
                        redis: health.redis === 'connected' ? 'up' : 'down',
                        sim: 'up', ollama: 'up'
                    });
                } catch (e) { }
            }, [currentRunId]);

            useEffect(() => {
                refreshData();
                const interval = setInterval(refreshData, 5000);
                return () => clearInterval(interval);
            }, [refreshData]);

            useEffect(() => {
                if (!currentRunId) return;
                const ws = new WebSocket(`ws://172.18.205.88:8000/ws/pipeline/${currentRunId}`);
                ws.onmessage = (event) => {
                    const data = JSON.parse(event.data);
                    if (data.type === 'ping') return;
                    setLogs(prev => [...prev, data]);
                };
                return () => ws.close();
            }, [currentRunId]);

            const handleDeploy = async () => {
                try {
                    setIsDeploying(true);
                    setLogs([]);
                    const res = await api.triggerPipeline({
                        firmware_path: "firmware/v1.2.0.bin",
                        device_profile: "rpi4",
                        firmware_image: "ubuntu:22.04"
                    });
                    if (res.run_id) setCurrentRunId(res.run_id);
                } catch (e) { setIsDeploying(false); }
            };

            const handleSendMessage = async () => {
                if (!chatMessage.trim() || !selectedRun) return;
                const userMsg = { role: 'user', content: chatMessage };
                setChatHistory(prev => [...prev, userMsg]);
                setChatMessage("");
                setIsTyping(true);
                try {
                    const res = await api.chat(selectedRun.id, chatMessage, activeModel);
                    setChatHistory(prev => [...prev, { role: 'assistant', content: res.response, model: res.model }]);
                } catch (e) { } finally { setIsTyping(false); }
            };

            const latestRun = runs[0];

            return React.createElement('div', { className: "flex w-full h-full bg-[#0d1117] text-white" },
                React.createElement('aside', { className: "w-64 bg-[#161b22] border-r border-[#30363d] flex flex-col" },
                    React.createElement('div', { className: "p-6 flex items-center gap-3" },
                        React.createElement('div', { className: "w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center font-bold" }, "⬡"),
                        React.createElement('span', { className: "font-bold text-lg" }, "Control Plane")
                    ),
                    React.createElement('nav', { className: "flex-1 px-4 space-y-1" },
                        [
                            { id: 'overview', icon: Icons.LayoutDashboard, label: 'Overview' },
                            { id: 'pipelines', icon: Icons.Play, label: 'Pipeline Runs' },
                            { id: 'ai', icon: Icons.MessageSquare, label: 'AI Console' },
                        ].map(item => React.createElement('button', {
                            key: item.id,
                            onClick: () => setActiveTab(item.id),
                            className: `w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all ${activeTab === item.id ? 'bg-blue-500/10 text-blue-500 font-bold' : 'text-gray-400 hover:bg-white/5 hover:text-white'}`
                        }, React.createElement(item.icon, { size: 18 }), item.label))
                    ),
                    React.createElement('div', { className: "p-4 border-t border-[#30363d]" },
                        React.createElement('button', { onClick: handleDeploy, className: "w-full bg-blue-500 hover:bg-blue-600 py-2.5 rounded-lg font-bold flex items-center justify-center gap-2" },
                            React.createElement(Icons.Plus, { size: 18 }), "Trigger Pipeline")
                    )
                ),
                React.createElement('main', { className: "flex-1 flex flex-col overflow-hidden" },
                    React.createElement('header', { className: "h-16 border-b border-[#30363d] flex items-center justify-between px-8" },
                        React.createElement('div', { className: "flex items-center gap-2 py-1.5 px-3 bg-white/5 rounded-full border border-[#30363d]" },
                            Object.entries(healthStatus).map(([key, val]) => React.createElement('div', { key: key, className: "flex items-center gap-1.5 px-2 border-r last:border-0 border-white/10" },
                                React.createElement('div', { className: `w-1.5 h-1.5 rounded-full ${val === 'up' ? 'bg-green-500' : 'bg-red-500'}` }),
                                React.createElement('span', { className: "text-[10px] font-mono uppercase text-gray-500" }, key)
                            ))
                        ),
                        React.createElement('div', { className: "flex items-center gap-2 text-xs text-gray-400 font-mono" },
                            React.createElement('span', { className: "w-2 h-2 rounded-full bg-green-500 animate-pulse" }), "SYSTEM LIVE")
                    ),
                    React.createElement('div', { className: "flex-1 overflow-y-auto p-8 custom-scrollbar" },
                        activeTab === 'overview' && React.createElement('div', null,
                            React.createElement('div', { className: "bg-[#161b22] rounded-2xl p-10 border border-[#30363d] mb-8" },
                                React.createElement('div', null,
                                    React.createElement('h3', { className: "text-gray-500 text-xs uppercase mb-4 tracking-widest" }, "Latest Decision"),
                                    latestRun ? React.createElement(React.Fragment, null,
                                        React.createElement('div', { className: `text-7xl font-bold font-mono flex items-center gap-6 ${latestRun.decision === 'BLOCK' ? 'text-red-500' : 'text-green-500'}` },
                                            latestRun.decision, latestRun.decision === 'BLOCK' ? React.createElement(Icons.XCircle, { size: 64 }) : React.createElement(Icons.CheckCircle2, { size: 64 })
                                        ),
                                        React.createElement('p', { className: "text-gray-400 mt-6 text-lg" }, 
                                            `Version ${latestRun.id.slice(0,8)} was ${latestRun.decision?.toLowerCase() || 'processed'} with ${(latestRun.confidence * 100).toFixed(1)}% confidence.`
                                        )
                                    ) : React.createElement('div', { className: "text-4xl text-gray-600 animate-pulse" }, "Awaiting data...")
                                )
                            ),
                            React.createElement('div', { className: "grid grid-cols-4 gap-6" },
                                [
                                    { label: 'Total Runs', val: runs.length },
                                    { label: 'Success Rate', val: `${Math.round((runs.filter(r => r.decision === 'DEPLOY').length / (runs.length || 1)) * 100)}%` },
                                    { label: 'Avg Confidence', val: (runs.reduce((acc, r) => acc + (r.confidence || 0), 0) / (runs.length || 1)).toFixed(2) },
                                    { label: 'Active Agents', val: '3' },
                                ].map((s, i) => React.createElement('div', { key: i, className: "bg-[#161b22] p-6 rounded-xl border border-[#30363d]" },
                                    React.createElement('div', { className: "text-xs text-gray-500 uppercase mb-2" }, s.label),
                                    React.createElement('div', { className: "text-3xl font-mono font-bold" }, s.val)
                                ))
                            )
                        ),
                        activeTab === 'pipelines' && React.createElement('div', { className: "bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden" },
                            React.createElement('table', { className: "w-full text-left" },
                                React.createElement('thead', { className: "bg-white/5 text-[11px] uppercase text-gray-500 font-bold" },
                                    React.createElement('tr', null,
                                        ['Run ID', 'Status', 'Confidence', 'Decision'].map(h => React.createElement('th', { key: h, className: "px-6 py-4" }, h))
                                    )
                                ),
                                React.createElement('tbody', { className: "divide-y divide-[#30363d]" },
                                    runs.map(run => React.createElement('tr', { key: run.id, onClick: () => setSelectedRun(run), className: `hover:bg-white/[0.02] cursor-pointer ${selectedRun?.id === run.id ? 'bg-blue-500/5' : ''}` },
                                        React.createElement('td', { className: "px-6 py-4 font-mono text-sm" }, run.id.slice(0, 8)),
                                        React.createElement('td', { className: "px-6 py-4 text-xs uppercase" }, run.status),
                                        React.createElement('td', { className: "px-6 py-4" }, (run.confidence * 100).toFixed(1) + '%'),
                                        React.createElement('td', { className: "px-6 py-4" }, React.createElement(DecisionBadge, { decision: run.decision }))
                                    ))
                                )
                            )
                        ),
                        activeTab === 'ai' && React.createElement('div', { className: "flex flex-col h-full bg-[#161b22] border border-[#30363d] rounded-xl overflow-hidden" },
                            React.createElement('div', { className: "p-4 border-b border-[#30363d] flex items-center justify-between" },
                                React.createElement('div', { className: "flex items-center gap-3 font-bold" },
                                    React.createElement(Icons.Sparkles, { size: 18, className: "text-blue-500" }), "AI Assistant",
                                    React.createElement('div', { className: "flex gap-1 ml-4" },
                                        ['phi3', 'deepseek'].map(m => React.createElement('button', {
                                            key: m, onClick: () => setActiveModel(m),
                                            className: `text-[10px] px-2 py-0.5 rounded border ${activeModel === m ? 'bg-blue-500/20 border-blue-500 text-blue-500' : 'border-[#30363d] text-gray-500'}`
                                        }, m.toUpperCase()))
                                    )
                                ),
                                selectedRun && React.createElement('span', { className: "text-[10px] font-mono text-gray-500" }, "Run: " + selectedRun.id.slice(0, 8))
                            ),
                            React.createElement('div', { className: "flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar" },
                                selectedRun ? (chatHistory.length === 0 ? React.createElement('div', { className: "text-center text-gray-500 py-10" }, "Ask about the reasoning...") :
                                    chatHistory.map((msg, i) => React.createElement('div', { key: i, className: `flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}` },
                                        React.createElement('div', { className: `max-w-[80%] rounded-xl px-4 py-2 text-sm ${msg.role === 'user' ? 'bg-blue-500 text-white' : 'bg-[#0d1117] border border-[#30363d]'}` }, msg.content)
                                    ))) : React.createElement('div', { className: "text-center text-gray-500 py-10" }, "Select a run in Pipelines tab")
                            ),
                            React.createElement('div', { className: "p-4 border-t border-[#30363d]" },
                                React.createElement('div', { className: "flex gap-2" },
                                    React.createElement('input', {
                                        placeholder: selectedRun ? "How did the safety check go?" : "Select a run first",
                                        disabled: !selectedRun,
                                        value: chatMessage,
                                        onChange: (e) => setChatMessage(e.target.value),
                                        onKeyDown: (e) => e.key === 'Enter' && handleSendMessage(),
                                        className: "flex-1 bg-[#0d1117] border border-[#30363d] rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-blue-500"
                                    }),
                                    React.createElement('button', { onClick: handleSendMessage, className: "p-2 bg-blue-500 rounded-lg hover:bg-blue-600" }, React.createElement(Icons.Send, { size: 18 }))
                                )
                            )
                        )
                    )
                ),
                isDeploying && currentRunId && React.createElement(LivePipeline, {
                        runId: currentRunId,
                        logs: logs,
                        onClose: () => { setIsDeploying(false); setCurrentRunId(null); setLogs([]); refreshData(); }
                    })
            );
        };

        const root = createRoot(document.getElementById('app'));
        root.render(React.createElement(App));
    </script>
</body>
</html>
